# Freelance & Consultancy section visibility
# true  = show Services section + "Freelance" nav + "Work with me" CTA (default)
# false = hide the whole freelance block; keep general Contact
NEXT_PUBLIC_SHOW_FREELANCE=true

# You can also flip `showFreelanceContent` in src/lib/content.ts
# Env wins when set to "true"/"false".
